generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
